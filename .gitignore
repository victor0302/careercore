node_modules/
.next/
out/
dist/
.npm
.eslintcache
*.tsbuildinfo
next-env.d.ts

# ── Docker ─────────────────────────────────────────────────────────────────────
# (docker-compose.override.yml is local only)
docker-compose.override.yml

# ── IDEs & OS ──────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Alembic ────────────────────────────────────────────────────────────────────
