# ══════════════════════════════════════════════════════════════════════════════
# CareerCore — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env.
# ══════════════════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────────────────
# "development" or "production" — controls error detail level and debug logging
APP_ENV=development
APP_VERSION=0.1.0

# ── Database ──────────────────────────────────────────────────────────────────
# Async PostgreSQL DSN (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://careercore:careercore@db:5432/careercore

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── MinIO (Object Storage) ────────────────────────────────────────────────────
MINIO_ENDPOINT=storage:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=careercore-uploads
# Short-lived download URLs for uploaded files (seconds)
FILE_DOWNLOAD_URL_TTL_SECONDS=300

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── AI Provider ───────────────────────────────────────────────────────────────
# Options: "anthropic" | "mock" (use "mock" in all test/CI environments)
AI_PROVIDER=mock

# Anthropic API key — required when AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-replace-me

# ── JWT Authentication ─────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace-me-with-a-secure-random-hex-string
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Token Budget (per user per day) ───────────────────────────────────────────
FREE_TIER_DAILY_TOKEN_BUDGET=50000
STANDARD_DAILY_TOKEN_BUDGET=200000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Frontend (Next.js public vars) ────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
