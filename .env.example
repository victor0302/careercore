# ══════════════════════════════════════════════════════════════════════════════
# CareerCore — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env.
# ══════════════════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────────────────
# APP_ENV controls error detail and debug logging.
# Valid values: "development" | "production"
APP_ENV=development

# Semantic version string surfaced by GET /health — update when cutting a release.
APP_VERSION=0.1.0

# ── Database ──────────────────────────────────────────────────────────────────
# Async PostgreSQL DSN (asyncpg driver). REQUIRED — startup fails without this.
# Docker Compose default points to the internal db service.
DATABASE_URL=postgresql+asyncpg://careercore:careercore@db:5432/careercore

# ── Redis ─────────────────────────────────────────────────────────────────────
# Used for rate limiting, budget caching, and Celery broker.
# REQUIRED — startup fails without this.
REDIS_URL=redis://redis:6379/0

# ── MinIO (Object Storage) ────────────────────────────────────────────────────
# Internal Docker network address (host:port) — do NOT include a scheme.
# REQUIRED — startup fails without MINIO_ENDPOINT, MINIO_ACCESS_KEY, MINIO_SECRET_KEY.
MINIO_ENDPOINT=storage:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Bucket name where user uploads are stored. Created automatically by storage_init.
MINIO_BUCKET=careercore-uploads

# Lifetime of presigned download URLs (seconds). Default: 300 (5 minutes).
FILE_DOWNLOAD_URL_TTL_SECONDS=300

# ── Celery ────────────────────────────────────────────────────────────────────
# Broker and result backend use separate Redis DB indices to avoid key collisions.
# REQUIRED — startup fails without these.
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── AI Provider ───────────────────────────────────────────────────────────────
# Controls which AI backend is used.
# Valid values: "anthropic" | "mock"
# Use "mock" in all test and CI environments — no API key needed.
AI_PROVIDER=mock

# Anthropic API key — required only when AI_PROVIDER=anthropic.
# Obtain from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-replace-me

# Claude model IDs used for each tier. Override to pin a version.
# Haiku is used for fast/cheap tasks; Sonnet for quality-sensitive tasks.
AI_HAIKU_MODEL=claude-haiku-4-5-20251001
AI_SONNET_MODEL=claude-sonnet-4-6

# Per-model cost in USD per million input tokens (JSON object string).
# Omit to use the built-in defaults. Override in production to track real costs.
# Example: '{"claude-haiku-4-5-20251001": 0.25, "claude-sonnet-4-6": 3.00, "default": 1.00}'
# AI_MODEL_PRICING_JSON=

# ── JWT Authentication ────────────────────────────────────────────────────────
# REQUIRED — startup fails without JWT_SECRET_KEY.
# Generate a secure value with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace-me-with-a-secure-random-hex-string

# Access token lifetime (minutes). Short-lived by design; clients use refresh tokens.
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15

# Refresh token lifetime (days). Rotation happens on every use.
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Token Budget (per user per day) ──────────────────────────────────────────
# Maximum total tokens a user may consume in a single UTC calendar day.
# Checked via AICostService.check_budget(); exceeding raises HTTP 429.
FREE_TIER_DAILY_TOKEN_BUDGET=50000
STANDARD_DAILY_TOKEN_BUDGET=200000

# ── AI Endpoint Rate Limits (sliding window, per user) ───────────────────────
# Analyze endpoint (POST /jobs/{id}/parse): controls how many requests a single
# user may make within the window before receiving HTTP 429 + Retry-After.
AI_ANALYZE_RATE_LIMIT_REQUESTS=5
AI_ANALYZE_RATE_LIMIT_WINDOW_SECONDS=3600

# Generate endpoint (POST /resumes/{id}/bullets): same semantics as above.
AI_GENERATE_RATE_LIMIT_REQUESTS=10
AI_GENERATE_RATE_LIMIT_WINDOW_SECONDS=3600

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for cross-origin requests.
# Add production domain(s) here when deploying.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Frontend (Next.js public vars) ────────────────────────────────────────────
# Exposed to the browser — must point to the publicly reachable API URL.
# In Docker Compose dev this is the host-mapped backend port.
NEXT_PUBLIC_API_URL=http://localhost:8000
